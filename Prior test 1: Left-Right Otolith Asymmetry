fixed_image_directory <- file.path(selected_images_base, "ShapeAnalysis", "Fixed")


# -----------------------------------------------------------
# SHAPE R ANALYSIS
# -----------------------------------------------------------

setwd(file.path(selected_images_base, "ShapeAnalysis"))

# Load ShapeR object
shape <- shapeR("/path/to/workspace/selected_images/ShapeAnalysis",
                "input_desired_samples.csv")

# Detect and smooth outlines
shape <- detect.outline(shape, threshold = 0.3, write.outline.w.org = TRUE)
shape <- smoothout(shape, n = 100)
save(shape, file = "right_left_pairs_good_verygood_perfectoutlines_smoothed.RData")


# Generate shape coefficients
shape <- generateShapeCoefficients(shape)
save(shape, file = "right_left_pairs_good_verygood_perfectoutlines_smoothed_coefficients.RData")

# Enrich master list with CSV columns
shape <- enrich.master.list(shape)

## Save shape coefficients:
shape_meas <- getMeasurements(shape)  

# Quick check: mean otolith area by side
tapply(getMeasurements(shape)$otolith.area, getMasterlist(shape)$side, mean)


# Add metadata from the master list
master <- getMasterlist(shape)
shape_meas$side     <- master$side
shape_meas$fish_id  <- master$base_name
shape_meas$pop      <- master$pop
shape_meas$length_cm <- master$length_cm
shape_meas$sex      <- master$sex
shape_meas$yr       <- master$yr
shape_meas$folder   <- master$folder
shape_meas$picname  <- master$picname

# ---------------------------------------------
# Compute shape indices
# ---------------------------------------------

shape_meas$Circularity <- (shape_meas$otolith.perimeter^2) / shape_meas$otolith.area

shape_meas$Rectangularity <- shape_meas$otolith.area /
                             (shape_meas$otolith.length * shape_meas$otolith.width)

shape_meas$Roundness <- (4 * shape_meas$otolith.area) /
                        (pi * (shape_meas$otolith.length^2))

shape_meas$Aspect_Ratio <- shape_meas$otolith.length / shape_meas$otolith.width

shape_meas$Form_Factor <- (4 * pi * shape_meas$otolith.area) /
                          (shape_meas$otolith.perimeter^2)

shape_meas$Ellipticity <- (shape_meas$otolith.length - shape_meas$otolith.width) /
                          (shape_meas$otolith.length + shape_meas$otolith.width)


# ---------------------------------------------
# Allometric Standardization of Shape Metrics
# ---------------------------------------------

# Clean side labels directly in shape object
shape@master.list$side <- as.character(shape@master.list$side)
shape@master.list$side <- tolower(trimws(shape@master.list$side))
shape@master.list$side <- factor(shape@master.list$side, levels = c("left", "right"))


# List of variables to standardize
measure_vars <- c("otolith.area", "otolith.length", "otolith.width", "otolith.perimeter",
                  "Circularity", "Rectangularity", "Roundness",
                  "Aspect_Ratio", "Form_Factor", "Ellipticity")

# Mean length
meanTL <- mean(shape_meas$length_cm, na.rm = TRUE)

# Standardization loop
for (var in measure_vars) {
  if (all(!is.na(shape_meas[[var]]))) {
    logMO <- log(shape_meas[[var]])
    logTL <- log(shape_meas$length_cm)
    b_model <- lm(logMO ~ logTL)
    b <- coef(b_model)[2]
    Ms <- exp(logMO + b * (log(meanTL) - logTL))
    var_std <- paste0(var, "_std")
    shape_meas[[var_std]] <- Ms
  }
}


# Save to CSV
write.csv(shape_meas, 
          file = "right_left_pairs_shape_indices.csv", 
          row.names = FALSE)



#this code just changes the indv name so that the side suffix is removed (there's another column for side specifically)
