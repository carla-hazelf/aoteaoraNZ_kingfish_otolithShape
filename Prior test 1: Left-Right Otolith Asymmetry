# ---------------------------------------------
# Left–Right Asymmetry Analysis
# ---------------------------------------------

# List of standardized shape indices to test
shape_vars <- c("Circularity_std", "Rectangularity_std", "Roundness_std", 
                "Aspect_Ratio_std", "Form_Factor_std", "Ellipticity_std")

asymmetry_results <- list()

# Loop over each variable
for (var in shape_vars) {
  
  # Ensure paired matching by fish_id
  left_vals <- shape_meas %>%
    filter(side == "left") %>%
    arrange(fish_id) %>%
    pull(!!sym(var))
  
  right_vals <- shape_meas %>%
    filter(side == "right") %>%
    arrange(fish_id) %>%
    pull(!!sym(var))
  
  # Check equal pairing
  if (length(left_vals) != length(right_vals)) {
    warning(paste("Mismatch in left/right samples for", var))
    next
  }

  # Differences
  diffs <- left_vals - right_vals

  # Shapiro-Wilk test for normality of differences
  shapiro <- shapiro.test(diffs)
  normality <- shapiro$p.value > 0.05

  # Conditional test
  if (normality) {
    test <- t.test(left_vals, right_vals, paired = TRUE)
    test_type <- "Paired t-test"
    stat_value <- round(test$statistic, 4)
    df_or_v <- round(test$parameter, 0)
  } else {
    test <- wilcox.test(left_vals, right_vals, paired = TRUE)
    test_type <- "Wilcoxon signed-rank"
    stat_value <- round(test$statistic, 4)
    df_or_v <- NA
  }

  # Save results
  asymmetry_results[[var]] <- data.frame(
    Variable = var,
    Mean_Left = round(mean(left_vals), 4),
    Mean_Right = round(mean(right_vals), 4),
    Mean_Diff = round(mean(diffs), 4),
    Test_Type = test_type,
    Statistic = stat_value,
    df_or_V = df_or_v,
    p_value = round(test$p.value, 4),
    Shapiro_p = round(shapiro$p.value, 4),
    Normality_Passed = normality
  )
}

# Combine and adjust p-values
asymmetry_df <- bind_rows(asymmetry_results) %>%
  mutate(p_value_adjusted_Holm = p.adjust(p_value, method = "holm"),
         p_value_adjusted_BH = p.adjust(p_value, method = "BH"))


print(asymmetry_df)

# Save
write.csv(asymmetry_df, "asymmetry_test_summary.csv", row.names = FALSE)


# ---------------------------------------------
# ANCOVA: Test interaction between side and fish length
# ---------------------------------------------

shape_vars <- c("Aspect_Ratio_std", "Circularity_std", "Ellipticity_std",
                "Form_Factor_std", "Rectangularity_std", "Roundness_std")

ancova_results <- list()

for (var in shape_vars) {
  
  formula_full <- as.formula(paste0(var, " ~ length_cm * side"))  # includes interaction
  formula_reduced <- as.formula(paste0(var, " ~ length_cm + side"))  # assumes common slope

  # Fit full and reduced models
  model_full <- lm(formula_full, data = shape_meas)
  model_reduced <- lm(formula_reduced, data = shape_meas)

  # Test for significant interaction
  anova_result <- anova(model_reduced, model_full)

  # Extract results
  ancova_results[[var]] <- data.frame(
    Variable = var,
    F_value = round(anova_result$`F`[2], 3),
    p_value = round(anova_result$`Pr(>F)`[2], 4),
    stringsAsFactors = FALSE
  )
}

# Combine
ancova_summary <- do.call(rbind, ancova_results)

# Adjust p-values (Holm and BH)
ancova_summary$p_adjust_Holm <- p.adjust(ancova_summary$p_value, method = "holm")
ancova_summary$p_adjust_BH <- p.adjust(ancova_summary$p_value, method = "BH")

print(ancova_summary)

# Save
write.csv(ancova_summary, "ancova_interaction_summary.csv", row.names = FALSE)


## Checking for ANCOVA assumptions


# Initialize list to store assumption test results
ancova_assumptions <- list()

# Loop through each shape variable
for (var in shape_vars) {

  # Define reduced ANCOVA model (used if interaction not significant)
  model_reduced <- lm(as.formula(paste0(var, " ~ length_cm + side")), data = shape_meas)
  
  # Extract residuals and fitted values
  residuals_model <- residuals(model_reduced)
  fitted_values <- fitted(model_reduced)
  
  # Test 1: Normality of residuals
  shapiro_res <- shapiro.test(residuals_model)

  # Test 2: Homoscedasticity using Levene's Test on residuals by side
  levene_res <- leveneTest(residuals_model ~ shape_meas$side)

  # Test 3: Linearity (indirect): Add quadratic term and test its significance
  shape_meas$temp_poly <- shape_meas$length_cm^2
  model_poly <- lm(as.formula(paste0(var, " ~ length_cm + temp_poly + side")), data = shape_meas)
  poly_summary <- summary(model_poly)
  poly_pval <- coef(poly_summary)["temp_poly", "Pr(>|t|)"]

  # Save results
  ancova_assumptions[[var]] <- data.frame(
    Variable = var,
    Shapiro_W_Residuals = round(shapiro_res$statistic, 4),
    Shapiro_p = round(shapiro_res$p.value, 4),
    Levene_F = round(levene_res[1, "F value"], 4),
    Levene_p = round(levene_res[1, "Pr(>F)"], 4),
    Poly_p = round(poly_pval, 4),
    Normality_Passed = shapiro_res$p.value > 0.05,
    Homoscedasticity_Passed = levene_res[1, "Pr(>F)"] > 0.05,
    Linearity_Passed = poly_pval > 0.05
  )
}

ancova_assumption_summary <- do.call(rbind, ancova_assumptions)

# Save results
write.csv(ancova_assumption_summary, "ancova_assumption_summary.csv", row.names = FALSE)

# View summary
print(ancova_assumption_summary)
